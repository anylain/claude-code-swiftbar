#!/bin/bash
# cc-status-writer — Claude Code hook script that writes session status to a
# small JSON file read by the SwiftBar plugin. Invoked by hooks configured in
# ~/.claude/settings.json (or project .claude/settings.json).
#
# Reads hook event JSON from stdin; writes ~/.claude/projects/<proj>/.cc-status.json
#
# CRITICAL: This script is invoked from UserPromptSubmit and other blocking
# hooks. Any non-zero exit will block the user's prompt. So we trap all errors
# and force exit 0 — a broken status file is acceptable, blocking the user is
# NOT. Validate any change with `bash -n` before saving.
set -uo pipefail
trap 'exit 0' ERR
command -v python3 >/dev/null 2>&1 || exit 0

# Source user-tunable env relayed by plugin.10s.sh (SwiftBar Preferences UI
# writes the user's CC_NOTIFY choice into the running plugin's env, which
# the plugin in turn writes here for hooks). Best-effort: missing file or
# parse error → fall back to defaults.
[ -r "$HOME/.claude/.cc-config.env" ] && . "$HOME/.claude/.cc-config.env" 2>/dev/null
export CC_NOTIFY="${CC_NOTIFY:-1}"

# Locate sibling .lib/ via this script's own path. Hook context doesn't set
# SWIFTBAR_PLUGIN_PACKAGE_PATH, and the script may be invoked through a
# symlink (install.sh symlinks the bundle into SwiftBar's plugin folder), so
# we resolve via $0 → .bin → .. → bundle root.
BIN_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB_DIR="$(cd "$BIN_DIR/../.lib" && pwd)"

# Save stdin to a temp file — write_status.py needs to read it, and it would
# also be consumed by the Stop-event filter below.
tmp="$(mktemp)"
cat > "$tmp"

# DEBUG (TEMPORARY): archive every Stop hook payload so we can inspect what
# Claude Code actually sends. Remove after diagnosing the "running stuck"
# issue. /tmp/cc-hook-stop-debug.log is appended (one JSON per line).
# Opt-in: only runs if CC_STATUS_HISTORY=1 or /tmp/cc-status-history.enabled exists.
if [ "${CC_STATUS_HISTORY:-}" = "1" ] || [ -e /tmp/cc-status-history.enabled ]; then
  if /usr/bin/python3 -S "$LIB_DIR/is_stop_event.py" "$tmp" 2>/dev/null; then
    {
      /bin/date '+%s %FT%T'
      cat "$tmp"
      echo
    } >> /tmp/cc-hook-stop-debug.log 2>/dev/null
  fi
fi

/usr/bin/python3 -S "$LIB_DIR/write_status.py" "$tmp" "$HOME"

# ── Notification hook (best-effort) ───────────────────────────────────────
# After the status file is written, decide whether to fire a macOS notification
# (only for needs-permission / needs-decision, only when the host window isn't
# focused). maybe_notify.py reads $tmp + .cc-status.json itself. Disable with
# CC_NOTIFY=0.
/usr/bin/python3 -S "$LIB_DIR/maybe_notify.py" "$tmp" >/dev/null 2>&1 || true

rm -f "$tmp"

# ── SwiftBar refresh: debounced by default ────────────────────────────────
# Hook events fire in clusters (PreToolUse + PostToolBatch + Stop within
# ~100ms). Trailing-edge debounce via /tmp/cc-swiftbar-lock-$UID collapses
# them into one refresh per 1s window to keep SwiftBar's CPU low.
#
# URL: we fire BOTH names back-to-back. Reason — SwiftBar's plugin-name lookup
# changes between releases and there's no single string that works on both:
#
#   - v2.0.1 (current release): no packaged-plugin support; our bundle is
#     scanned as a plain directory and `plugin.10s.sh` is loaded as
#     ExecutablePlugin → id="plugin.10s.sh", name="plugin". `?name=claude-code`
#     finds nothing and is silently dropped.
#   - main branch (untagged as of 2026-06): packaged-plugin support landed.
#     `claude-code.swiftbar/` is loaded as PackagedPlugin → name="claude-code".
#     The bundle's inner `plugin.10s.sh` is no longer registered as its own
#     plugin, so `?name=plugin.10s.sh` finds nothing.
#
# Firing both URLs is cheap: SwiftBar's `getPluginByNameOrID` is an O(n)
# lookup over a tiny plugin list and does nothing on miss. Whichever name is
# valid for the running SwiftBar version refreshes us; the other no-ops.
# When the v2.0.1 install base is gone we can drop the `plugin.10s.sh` URL.
#
# Cost: state changes lag ~1s before reaching the menu bar. To verify or
# debug a state-change timing issue, disable debounce:
#   CC_REFRESH_DEBOUNCE=0 (env var) OR `touch /tmp/cc-refresh-debounce.disabled`
# Then refresh fires immediately on every hook event.
fire_refresh() {
  # v2.0.1: matches id="plugin.10s.sh"
  /usr/bin/open -g "swiftbar://refreshplugin?name=plugin.10s.sh" 2>/dev/null || true
  # post-packaged-plugin SwiftBar: matches name="claude-code"
  /usr/bin/open -g "swiftbar://refreshplugin?name=claude-code" 2>/dev/null || true
}
if [ "${CC_REFRESH_DEBOUNCE:-1}" = "0" ] || [ -e /tmp/cc-refresh-debounce.disabled ]; then
  fire_refresh
else
  # Stale lock recovery: > 5s old means the prior worker was SIGKILL'd
  # and its EXIT trap never ran — without recovery the lock would silence
  # all future refreshes until reboot.
  LOCK="/tmp/cc-swiftbar-lock-$UID"
  if [ -e "$LOCK" ]; then
    if /usr/bin/python3 -S -c "import os, sys, time; sys.exit(0 if time.time() - os.path.getmtime('$LOCK') > 5 else 1)" 2>/dev/null; then
      rm -f "$LOCK"
    else
      exit 0
    fi
  fi
  (
    : > "$LOCK"
    trap 'rm -f "$LOCK"' EXIT
    sleep 1
    fire_refresh
  ) </dev/null >/dev/null 2>&1 &
fi

# Belt-and-suspenders: never let this hook block the user's prompt.
exit 0
